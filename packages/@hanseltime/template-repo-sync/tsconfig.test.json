// Base ESM tsconfig file for builds
{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		// Remove the rootDir restriction so that we can transpile whatever lib dir they used
		"rootDir": null,
		"inlineSourceMap": true
	},
	"exclude": [
		"node_modules/**/*",
		"test-fixtures/**/*",
		"lib/**/*",
		"src/**/*.spec.ts"
	]
}
